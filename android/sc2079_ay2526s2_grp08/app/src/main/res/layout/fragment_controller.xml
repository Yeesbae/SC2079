<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvSelectedSmall"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingBottom="6dp"
        android:text="Selected: Obs 1"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Obstacle selector -->
    <LinearLayout
        android:id="@+id/obstacleGridSmall"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tvSelectedSmall"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnObs1"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif-medium"
                android:text="1"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnObs2"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif-medium"
                android:text="2"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnObs3"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif-medium"
                android:text="3"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnObs4"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif-medium"
                android:text="4"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnObs5"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif-medium"
                android:text="5"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnObs6"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif-medium"
                android:text="6"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnObs7"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif-medium"
                android:text="7"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnObs8"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif-medium"
                android:text="8"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Arena Preview Area (square) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/arenaContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/obstacleGridSmall"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1">

        <com.example.sc2079_ay2526s2_grp08.ui.arena.ArenaView
            android:id="@+id/arenaView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@android:color/white"
            android:paddingLeft="18dp"
            android:paddingBottom="18dp"
            android:paddingRight="6dp"
            android:paddingTop="6dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom panel -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomPanel"
        android:layout_width="0dp"
        android:layout_height="274dp"
        android:layout_marginBottom="4dp"
        android:paddingTop="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/leftPanel"
            android:layout_width="220dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:paddingEnd="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <!-- Chat title -->
            <TextView
                android:id="@+id/tvChatTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chat"
                android:textStyle="bold"
                android:textSize="14sp"
                android:paddingBottom="4dp"/>

            <!-- Chat transcript -->
            <ScrollView
                android:id="@+id/chatScroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="2"
                android:fillViewport="true"
                android:background="@android:color/white"
                android:padding="6dp">

                <TextView
                    android:id="@+id/tvChatTranscript"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:typeface="monospace"
                    android:textIsSelectable="true"
                    android:text=""/>
            </ScrollView>

            <!-- Chat input row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <EditText
                    android:id="@+id/etChatInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Raw..."
                    android:singleLine="true"
                    android:imeOptions="actionSend"/>

                <Button
                    android:id="@+id/btnChatSend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Send"/>
            </LinearLayout>

            <!-- D-pad container -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/dpad"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnForward"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="↑"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <Button
                    android:id="@+id/btnLeft"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="52dp"
                    android:text="←"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btnForward" />

                <Button
                    android:id="@+id/btnRight"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="52dp"
                    android:text="→"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btnForward" />

                <Button
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="↓"
                    app:layout_constraintTop_toBottomOf="@id/btnLeft"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

        <ScrollView
            android:id="@+id/infoScroll"
            android:layout_width="150dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:paddingStart="6dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/leftPanel"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/infoPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvConnStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Connection: -"
                    android:textStyle="bold"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvRobotLoc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Robot: (x,y,dir)"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/tvRunTimer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run Time: 00:00"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingTop="6dp"/>

                <Button
                    android:id="@+id/btnExplore"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:text="Start Explore"
                    android:layout_marginTop="8dp"/>

                <Button
                    android:id="@+id/btnFastest"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:text="Start Fastest Path"
                    android:layout_marginTop="6dp"/>

                <Button
                    android:id="@+id/btnReset"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:text="Reset"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>
        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
